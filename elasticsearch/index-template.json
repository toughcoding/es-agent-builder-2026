{
  "index_patterns": ["radiation-dashboard-*"],
  "template": {
    "mappings": {
      "properties": {
        "@timestamp":            { "type": "date" },
        "station_id":            { "type": "integer" },
        "station_name":          { "type": "keyword" },
        "location":              { "type": "geo_point" },
        "altitude_m":            { "type": "integer" },
        "has_weather_station":   { "type": "boolean" },
        "has_radiation_station": { "type": "boolean" },
        "radiation_urh":         { "type": "float" },
        "radiation_nsvh":        { "type": "float" },
        "radiation_missing":     { "type": "boolean" }
      }
    }
  }
}